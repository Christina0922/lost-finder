# LostFinder 클라이언트 환경변수 설정 예시
# 이 파일을 복사하여 .env 파일로 만들고 실제 값을 입력하세요

# API 기본 URL
REACT_APP_API_BASE_URL=http://localhost:5000/api
REACT_APP_SERVER_URL=http://localhost:5000

# 카카오맵 API 키 (JavaScript Key)
# 카카오 개발자 콘솔에서 발급받은 JavaScript Key를 입력하세요
REACT_APP_KAKAO_MAP_API_KEY=your-kakao-map-javascript-key-here

# 서버 환경변수 설정
PORT=5000
NODE_ENV=development

# 데이터베이스 설정 (실제 운영시에는 실제 DB 정보 사용)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lostfinder
DB_USER=lostfinder_user
DB_PASSWORD=your_secure_password_here

# JWT 시크릿 키 (실제 운영시에는 강력한 랜덤 키 사용)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# 이메일 설정 (실제 운영시에는 실제 SMTP 정보 사용)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# SMS 설정 (실제 운영시에는 실제 SMS 서비스 정보 사용)
SMS_API_KEY=your_sms_api_key_here
SMS_API_SECRET=your_sms_api_secret_here

# 파일 업로드 설정
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# CORS 설정
CORS_ORIGIN=http://localhost:3000

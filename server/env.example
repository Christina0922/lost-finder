# LostFinder 환경변수 설정 예시
# 이 파일을 복사하여 .env 파일로 만들고 실제 값을 입력하세요

# 데이터베이스 설정
DB_PATH=users.db

# 이메일 설정 (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# JWT 시크릿 키
JWT_SECRET=your-super-secret-jwt-key-here

# 카카오맵 API 키 (REST API Key)
# 카카오 개발자 콘솔에서 발급받은 REST API Key를 입력하세요
KAKAO_MAP_API_KEY=your-kakao-map-rest-api-key-here

# 서버 설정
PORT=5000
NODE_ENV=development

# CORS 설정
CORS_ORIGIN=http://localhost:3000,http://172.30.1.44:3000

# 세션 설정
SESSION_SECRET=your-session-secret-key-here